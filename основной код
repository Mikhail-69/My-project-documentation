#include "ListSerializer.h"
#include <fstream>
#include <iostream>

ListSerializer::ListSerializer() {
    head = nullptr;
}

ListSerializer::~ListSerializer() {
    clear();
}
//очистка 
void ListSerializer::clear() {
    for (int i = 0; i < (int)nodes.size(); i++) {
        delete nodes[i];
    }
    nodes.clear();
    loaded_data.clear();
    loaded_rand_indexes.clear();
    head = nullptr;
}
//чтение
bool ListSerializer::loadFromFile(const std::string& filename) {
    clear();

    std::ifstream fin(filename.c_str());
    if (!fin.is_open()) {
        return false;
    }

    std::string line;
    while (getline(fin, line)) {
        int pos = line.find(';');
        if (pos == -1) {
            continue; //пропускаем если нет 
        }

        std::string data = line.substr(0, pos);
        std::string index_str = line.substr(pos + 1);

        int rand_index = std::stoi(index_str); //преобразование string-int

        loaded_data.push_back(data);
        loaded_rand_indexes.push_back(rand_index);
    }

    fin.close();
    return loaded_data.size() > 0;
}

bool ListSerializer::buildList() {
    if (loaded_data.empty()) {
        return false;
    }
    for (int i = 0; i < (int)nodes.size(); i++) {
        delete nodes[i];
    }
    nodes.clear();

    for (int i = 0; i < (int)loaded_data.size(); i++) {
        ListNode* node = new ListNode();
        node->data = loaded_data[i]; //копирвание строки
        nodes.push_back(node);
    }

    int node_count = (int)nodes.size();
    for (int i = 0; i < node_count; i++) {
        if (i > 0) {
            nodes[i]->prev = nodes[i - 1]; //предыдущий узел
        }
        if (i < node_count - 1) {
            nodes[i]->next = nodes[i + 1]; //некст узел
        }
    }

    for (int i = 0; i < node_count; i++) {
        int rand_idx = loaded_rand_indexes[i];
        if (rand_idx != -1) {
            if (rand_idx >= 0 && rand_idx < node_count) {
                nodes[i]->rand = nodes[rand_idx]; //нахождение узла по индексу
            }
        }
    }

    head = nodes.empty() ? nullptr : nodes[0];
    return true;
}

bool ListSerializer::serialize(const std::string& filename) {
    if (head == nullptr) {
        return false;
    }

    std::ofstream fout(filename.c_str(), std::ios::binary);
    if (!fout.is_open()) {
        return false;
    }

    int node_count = (int)nodes.size();
    fout.write((char*)&node_count, sizeof(int)); //кол-во

    for (int i = 0; i < node_count; i++) {
        int len = (int)nodes[i]->data.length();
        fout.write((char*)&len, sizeof(int)); //длина
        fout.write(nodes[i]->data.c_str(), len); //байты

        int rand_idx = -1;
        if (nodes[i]->rand != nullptr) {
            for (int j = 0; j < node_count; j++) {
                if (nodes[j] == nodes[i]->rand) {
                    rand_idx = j;
                    break;
                }
            }
        }
        fout.write((char*)&rand_idx, sizeof(int));
    }

    fout.close();
    return true;
}

int main() {
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);
    ListSerializer serializer;

    std::cout << "загружаем inlet.in:" << std::endl;
    if (!serializer.loadFromFile("inlet.in")) {
        std::cout << "ошибка: не могу прочитать inlet.in" << std::endl;
        return 1;
    }

    std::cout << "строим список:" << std::endl;
    if (!serializer.buildList()) {
        std::cout << "ошибка:не могу прочитать список" << std::endl;
        return 1;
    }

    std::cout << "сохраняем в outlet.out:" << std::endl;
    if (!serializer.serialize("outlet.out")) {
        std::cout << "ошибка: не могу сохранить файл" << std::endl;
        return 1;
    }

    std::cout << "конец работы" << std::endl;
    return 0;
}