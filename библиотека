#ifndef LIST_SERIALIZER_H
#define LIST_SERIALIZER_H

#include <string>
#include <vector>
#include <Windows.h>
struct ListNode {
    ListNode* prev = nullptr; //указатель на предыдущий узел
    ListNode* next = nullptr; //указатель на некст узел
    ListNode* rand = nullptr; //указатель на рандомный узел списка
    std::string data;
};

class ListSerializer {
public:
    ListSerializer();
    ~ListSerializer();

    bool loadFromFile(const std::string& filename);
    bool buildList();
    bool serialize(const std::string& filename);

private:
    std::vector<std::string> loaded_data; //хран строк
    std::vector<int> loaded_rand_indexes; //хран индексов
    std::vector<ListNode*> nodes; //массив узлов
    ListNode* head; // начало списка

    void clear();
};

#endif